{
  "name": "iobroker.rpi-io",
  "version": "0.0.1",
  "description": "iobroker io adapter for raspberry pi",
  "author": {
    "name": "Albert Salai",
    "email": "albert2013@salai.de"
  },
  "homepage": "https://github.com/albert-salai/ioBroker.rpi-io",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "template",
    "Smart Home",
    "home automation"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:albert-salai/ioBroker.rpi-io.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "async-mutex": "^0.5.0",
    "debounce": "^3.0.0",
    "deep-diff": "^1.0.2",
    "i2c-bus": "^5.2.3",
    "iobroker-utils": "file:../ioBroker.utils",
    "rpio": "^2.4.2",
    "sprintf-js": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/types": "^7.1.1",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "~22",
    "@types/rpio": "^2.4.6",
    "@types/sprintf-js": "^1.1.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test": "echo \"No tests\"",
    "check": "tsc --noEmit",
    "lint": "eslint",
    "translate": "translate-adapter"
  },
  "bugs": {
    "url": "https://github.com/albert-salai/ioBroker.rpi-io/issues"
  },
  "readmeFilename": "README.md"
